@page
@model DriverRewards.Pages.ProfileModel
@{
    ViewData["Title"] = "Edit Profile";
}

<div class="row g-4">
    <div class="col-12">
        <h1 class="h3 mb-1">Edit Profile</h1>
        <p class="text-muted mb-0">Update your driver details and request sponsor changes.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="col-12">
            <div class="alert alert-info" role="alert">
                @Model.StatusMessage
            </div>
        </div>
    }

    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h5">Profile Details</h2>
                <form method="post" asp-page-handler="Profile">
                    <div class="mb-3">
                        <label class="form-label" asp-for="Profile.Email"></label>
                        <input class="form-control" asp-for="Profile.Email" />
                        <span class="text-danger small" asp-validation-for="Profile.Email"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="Profile.Username"></label>
                        <input class="form-control" asp-for="Profile.Username" />
                        <span class="text-danger small" asp-validation-for="Profile.Username"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="Profile.FedexId"></label>
                        <input class="form-control" asp-for="Profile.FedexId" />
                        <span class="text-danger small" asp-validation-for="Profile.FedexId"></span>
                    </div>

                    <hr />
                    <h3 class="h6">Saved Shipping Address</h3>

                    <div class="mb-3">
                        <label class="form-label" asp-for="Profile.ShippingFullName"></label>
                        <input class="form-control" asp-for="Profile.ShippingFullName" />
                        <span class="text-danger small" asp-validation-for="Profile.ShippingFullName"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="Profile.ShippingAddressLine1"></label>
                        <input class="form-control" asp-for="Profile.ShippingAddressLine1" />
                        <span class="text-danger small" asp-validation-for="Profile.ShippingAddressLine1"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="Profile.ShippingAddressLine2"></label>
                        <input class="form-control" asp-for="Profile.ShippingAddressLine2" />
                        <span class="text-danger small" asp-validation-for="Profile.ShippingAddressLine2"></span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label" asp-for="Profile.ShippingCity"></label>
                            <input class="form-control" asp-for="Profile.ShippingCity" />
                            <span class="text-danger small" asp-validation-for="Profile.ShippingCity"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" asp-for="Profile.ShippingState"></label>
                            <input class="form-control" asp-for="Profile.ShippingState" />
                            <span class="text-danger small" asp-validation-for="Profile.ShippingState"></span>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label" asp-for="Profile.ShippingPostalCode"></label>
                            <input class="form-control" asp-for="Profile.ShippingPostalCode" />
                            <span class="text-danger small" asp-validation-for="Profile.ShippingPostalCode"></span>
                        </div>
                    </div>

                    <div class="mt-3 mb-3">
                        <label class="form-label" asp-for="Profile.ShippingCountry"></label>
                        <input class="form-control" asp-for="Profile.ShippingCountry" />
                        <span class="text-danger small" asp-validation-for="Profile.ShippingCountry"></span>
                    </div>

                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h5">Sponsor Change Request</h2>
                <p class="text-muted small">Current sponsor(s): <strong>@(Model.CurrentSponsors.Count > 0 ? string.Join(", ", Model.CurrentSponsors) : "None")</strong></p>
                <form method="post" asp-page-handler="Sponsor">
                    <div class="mb-3">
                        <label class="form-label" asp-for="SponsorRequest.RequestedSponsor"></label>
                        <input class="form-control" asp-for="SponsorRequest.RequestedSponsor" />
                        <span class="text-danger small" asp-validation-for="SponsorRequest.RequestedSponsor"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="SponsorRequest.Note"></label>
                        <textarea class="form-control" rows="3" asp-for="SponsorRequest.Note"></textarea>
                        <span class="text-danger small" asp-validation-for="SponsorRequest.Note"></span>
                    </div>

                    <button type="submit" class="btn btn-outline-primary">Submit Request</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card shadow-sm border-danger">
            <div class="card-body">
                <h2 class="h5 text-danger">Delete Account</h2>
                <p class="text-muted small">This action is permanent and cannot be undone. All your data will be deleted.</p>
                <form method="post" asp-page-handler="DeleteAccount" onsubmit="return confirm('Are you sure you want to delete your account? This action cannot be undone.');">
                    <button type="submit" class="btn btn-danger">Delete My Account</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
