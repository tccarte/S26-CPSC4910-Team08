@page
@model DriverRewards.Pages.Sponsor.BulkMessageModel
@{
    ViewData["Title"] = "Send Bulk Message";
}

<div class="mb-4">
    <h1 class="mb-1">Send Bulk Message</h1>
    <p class="text-muted">Send a message to all @Model.DriverCount driver@(Model.DriverCount == 1 ? "" : "s") in your organization. It will appear in their notification inbox.</p>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success">@Model.StatusMessage</div>
}

<div class="row">
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Message" class="form-label fw-semibold">Message</label>
                        <textarea asp-for="Message" class="form-control" rows="5"
                                  placeholder="Write your message here..." maxlength="500"></textarea>
                        <div class="d-flex justify-content-between">
                            <span asp-validation-for="Message" class="text-danger small"></span>
                            <span class="text-muted small ms-auto">500 characters max</span>
                        </div>
                    </div>

                    @if (Model.DriverCount == 0)
                    {
                        <div class="alert alert-warning mb-3">You have no drivers in your organization yet.</div>
                    }

                    <button type="submit" class="btn btn-primary w-100" @(Model.DriverCount == 0 ? "disabled" : "")
                            onclick="return confirm('Send this message to all @Model.DriverCount driver@(Model.DriverCount == 1 ? "" : "s")?');">
                        Send to All Drivers
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
