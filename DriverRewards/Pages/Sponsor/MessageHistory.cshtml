@page
@model DriverRewards.Pages.Sponsor.MessageHistoryModel

@{
    ViewData["Title"] = "Message History";
}

<h1>Message History</h1>

<p>
    Review sponsor messages previously delivered to your drivers.
</p>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info" role="alert">
        @Model.StatusMessage
    </div>
}

<form method="get" class="mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-md-4">
            <label asp-for="Search" class="form-label">Search message text</label>
            <input asp-for="Search" class="form-control" placeholder="Enter keyword" />
        </div>

        <div class="col-md-3">
            <label asp-for="FromDate" class="form-label">From</label>
            <input asp-for="FromDate" class="form-control" type="date" />
        </div>

        <div class="col-md-3">
            <label asp-for="ToDate" class="form-label">To</label>
            <input asp-for="ToDate" class="form-control" type="date" />
        </div>

        <div class="col-md-2 d-grid">
            <button type="submit" class="btn btn-primary">Filter</button>
        </div>
    </div>
</form>

<div class="mb-3">
    <strong>Total deliveries:</strong> @Model.TotalCount
</div>

@if (Model.Messages.Count == 0)
{
    <div class="alert alert-secondary" role="alert">
        No sponsor messages were found for the selected filters.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead>
                <tr>
                    <th>Sent</th>
                    <th>Driver</th>
                    <th>Message</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Messages)
                {
                    <tr>
                        <td>@item.CreatedAtLocal.ToString("g")</td>
                        <td>
                            <div>@item.DriverName</div>
                            <small class="text-muted">@item.DriverEmail</small>
                        </td>
                        <td>@item.Message</td>
                        <td>
                            @if (item.IsRead)
                            {
                                <span class="badge bg-success">Read</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Unread</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}