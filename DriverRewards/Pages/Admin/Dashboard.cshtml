@page
@model DriverRewards.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="row g-4">
    <div class="col-12">
        <h1 class="h3 mb-1">Admin Dashboard</h1>
        <p class="text-muted mb-0">Review sponsor change requests and user lists.</p>
    </div>

    <div class="col-12">
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary" asp-page="/Admin/CreateDriver">Create Driver Account</a>
            <a class="btn btn-outline-primary" asp-page="/Admin/CreateSponsor">Create Sponsor Account</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="col-12">
            <div class="alert alert-info mb-0">@Model.StatusMessage</div>
        </div>
    }

    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                        <h2 class="h5 mb-1">Audit Snapshot</h2>
                        <p class="text-muted mb-0">Recent system activity across data changes, sign-ins, carts, orders, and notifications.</p>
                    </div>
                    <a class="btn btn-sm btn-outline-primary" asp-page="/Admin/Audit">Open Audit Center</a>
                </div>

                <div class="row g-3 mt-1">
                    <div class="col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">Audit Entries (24h)</div>
                            <div class="fs-4 fw-bold">@Model.AuditEntriesLast24Hours</div>
                        </div>
                    </div>
                    <div class="col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">Failures / Blocks (24h)</div>
                            <div class="fs-4 fw-bold text-danger">@Model.FailedAuditEntriesLast24Hours</div>
                        </div>
                    </div>
                    <div class="col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">New-IP Logins (24h)</div>
                            <div class="fs-4 fw-bold text-warning">@Model.NewIpEventsLast24Hours</div>
                        </div>
                    </div>
                    <div class="col-md-6 col-xl-3">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">Locked Accounts</div>
                            <div class="fs-4 fw-bold">@Model.LockedAccountCount</div>
                        </div>
                    </div>
                </div>

                @if (Model.RecentAuditEntries.Count == 0)
                {
                    <p class="text-muted mt-3 mb-0">No audit entries yet.</p>
                }
                else
                {
                    <div class="table-responsive mt-3">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>When</th>
                                    <th>Category</th>
                                    <th>Action</th>
                                    <th>Actor</th>
                                    <th>Description</th>
                                    <th>IP</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var audit in Model.RecentAuditEntries)
                                {
                                    <tr>
                                        <td>@audit.OccurredAt</td>
                                        <td>@audit.Category</td>
                                        <td>@audit.Action</td>
                                        <td>@audit.Actor</td>
                                        <td>@audit.Description</td>
                                        <td>@audit.IpAddress</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h5">Pending Sponsor Change Requests</h2>
                @if (Model.PendingRequests.Count == 0)
                {
                    <p class="text-muted mb-0">No pending requests.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Driver</th>
                                    <th>Email</th>
                                    <th>Current Sponsor</th>
                                    <th>Requested Sponsor</th>
                                    <th>Submitted</th>
                                    <th>Note</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var request in Model.PendingRequests)
                                {
                                    <tr>
                                        <td>@request.DriverName</td>
                                        <td>@request.DriverEmail</td>
                                        <td>@request.CurrentSponsor</td>
                                        <td>@request.RequestedSponsor</td>
                                        <td>@request.CreatedAt</td>
                                        <td>@request.Note</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h5">Pending Sponsor Approvals</h2>
                @if (Model.PendingSponsors.Count == 0)
                {
                    <p class="text-muted mb-0">No pending sponsor accounts.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Phone</th>
                                    <th>Submitted</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sponsor in Model.PendingSponsors)
                                {
                                    <tr>
                                        <td>@sponsor.Name</td>
                                        <td>@sponsor.Email</td>
                                        <td>@sponsor.Phone</td>
                                        <td>@sponsor.CreatedAt</td>
                                        <td class="text-end">
                                            <div class="d-inline-flex gap-2">
                                                <form method="post" asp-page-handler="ApproveSponsor">
                                                    <input type="hidden" name="sponsorId" value="@sponsor.SponsorId" />
                                                    <button type="submit" class="btn btn-sm btn-success">Approve</button>
                                                </form>
                                                <form method="post" asp-page-handler="RejectSponsor">
                                                    <input type="hidden" name="sponsorId" value="@sponsor.SponsorId" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">Reject</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h2 class="h5">Registered Drivers (@Model.Drivers.Count)</h2>
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Username</th>
                                <th>Email</th>
                                <th>Sponsor</th>
                                <th>FedEx ID</th>
                                <th>Created</th>
                                <th>Last Login</th>
                                <th>Last Login IP</th>
                                <th>Last Failed IP</th>
                                <th>Failed Attempts</th>
                                <th>Lockout Ends</th>
                                <th>Status</th>
                                <th>Points</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var driver in Model.Drivers)
                            {
                                <tr>
                                    <td>@driver.Username</td>
                                    <td>@driver.Email</td>
                                    <td>@driver.Sponsor</td>
                                    <td>@driver.FedexId</td>
                                    <td>@driver.CreatedAt</td>
                                    <td>@driver.LastLoginAt</td>
                                    <td>@driver.LastLoginIp</td>
                                    <td>@driver.LastFailedLoginIp</td>
                                    <td>@driver.FailedLoginAttempts</td>
                                    <td>@driver.LockoutEndAt</td>
                                    <td>
                                        @if (driver.IsSuspended)
                                        {
                                            <span class="badge bg-danger">Suspended</span>
                                        }
                                        else if (driver.MustResetPassword)
                                        {
                                            <span class="badge bg-warning text-dark">Reset Required</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                    </td>
                                    <td>@driver.Points</td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end align-items-center gap-2">
                                            <form method="post" asp-page-handler="AddDriverPoints" class="d-flex align-items-center gap-1">
                                                <input type="hidden" name="driverId" value="@driver.DriverId" />
                                                <input type="number" name="pointsToAdd" min="1" step="1" class="form-control form-control-sm" style="width: 90px;" placeholder="+Pts" />
                                                <button type="submit" class="btn btn-sm btn-outline-success">Add</button>
                                            </form>
                                            <div class="dropdown">
                                                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                                    &#x22EE;
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end">
                                                    <li>
                                                        <a class="dropdown-item" asp-page="/Admin/SponsorCatalog" asp-route-id="@driver.DriverId">View assigned sponsor catalog</a>
                                                    </li>
                                                    <li>
                                                        <a class="dropdown-item" asp-page="/Admin/EditDriver" asp-route-id="@driver.DriverId">Edit account</a>
                                                    </li>
                                                    <li>
                                                        <form method="post" asp-page-handler="ForceDriverReset">
                                                            <input type="hidden" name="driverId" value="@driver.DriverId" />
                                                            <button type="submit" class="dropdown-item">Require password reset</button>
                                                        </form>
                                                    </li>
                                                    <li>
                                                        <form method="post" asp-page-handler="RevokeSessions">
                                                            <input type="hidden" name="role" value="Driver" />
                                                            <input type="hidden" name="userId" value="@driver.DriverId" />
                                                            <button type="submit" class="dropdown-item">Revoke active sessions</button>
                                                        </form>
                                                    </li>
                                                    <li>
                                                        @if (driver.IsSuspended)
                                                        {
                                                            <form method="post" asp-page-handler="UnsuspendDriver">
                                                                <input type="hidden" name="driverId" value="@driver.DriverId" />
                                                                <button type="submit" class="dropdown-item text-success">Unsuspend account</button>
                                                            </form>
                                                        }
                                                        else
                                                        {
                                                            <form method="post" asp-page-handler="SuspendDriver">
                                                                <input type="hidden" name="driverId" value="@driver.DriverId" />
                                                                <button type="submit" class="dropdown-item text-warning">Suspend account</button>
                                                            </form>
                                                        }
                                                    </li>
                                                    <li>
                                                        <form method="post" asp-page-handler="RemoveDriver">
                                                            <input type="hidden" name="driverId" value="@driver.DriverId" />
                                                            <button type="submit" class="dropdown-item text-danger">Remove account</button>
                                                        </form>
                                                    </li>
                                                </ul>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h2 class="h5">Registered Sponsors (@Model.Sponsors.Count)</h2>
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Dollar/Point</th>
                                <th>Created</th>
                                <th>Last Login</th>
                                <th>Last Login IP</th>
                                <th>Last Failed IP</th>
                                <th>Failed Attempts</th>
                                <th>Lockout Ends</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sponsor in Model.Sponsors)
                            {
                                <tr>
                                    <td>@sponsor.Name</td>
                                    <td>@sponsor.Email</td>
                                    <td>@sponsor.Phone</td>
                                    <td>@sponsor.DollarToPointRatio</td>
                                    <td>@sponsor.CreatedAt</td>
                                    <td>@sponsor.LastLoginAt</td>
                                    <td>@sponsor.LastLoginIp</td>
                                    <td>@sponsor.LastFailedLoginIp</td>
                                    <td>@sponsor.FailedLoginAttempts</td>
                                    <td>@sponsor.LockoutEndAt</td>
                                    <td>
                                        @if (sponsor.IsSuspended)
                                        {
                                            <span class="badge bg-danger">Suspended</span>
                                        }
                                        else if (sponsor.MustResetPassword)
                                        {
                                            <span class="badge bg-warning text-dark">Reset Required</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="dropdown">
                                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                                &#x22EE;
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li>
                                                    <a class="dropdown-item" asp-page="/Admin/SponsorCatalog" asp-route-sponsorId="@sponsor.SponsorId">View catalog</a>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item" asp-page="/Admin/EditSponsor" asp-route-id="@sponsor.SponsorId">Edit account</a>
                                                </li>
                                                <li>
                                                    <form method="post" asp-page-handler="ForceSponsorReset">
                                                        <input type="hidden" name="sponsorId" value="@sponsor.SponsorId" />
                                                        <button type="submit" class="dropdown-item">Require password reset</button>
                                                    </form>
                                                </li>
                                                <li>
                                                    <form method="post" asp-page-handler="RevokeSessions">
                                                        <input type="hidden" name="role" value="Sponsor" />
                                                        <input type="hidden" name="userId" value="@sponsor.SponsorId" />
                                                        <button type="submit" class="dropdown-item">Revoke active sessions</button>
                                                    </form>
                                                </li>
                                                <li>
                                                    @if (sponsor.IsSuspended)
                                                    {
                                                        <form method="post" asp-page-handler="UnsuspendSponsor">
                                                            <input type="hidden" name="sponsorId" value="@sponsor.SponsorId" />
                                                            <button type="submit" class="dropdown-item text-success">Unsuspend account</button>
                                                        </form>
                                                    }
                                                    else
                                                    {
                                                        <form method="post" asp-page-handler="SuspendSponsor">
                                                            <input type="hidden" name="sponsorId" value="@sponsor.SponsorId" />
                                                            <button type="submit" class="dropdown-item text-warning">Suspend account</button>
                                                        </form>
                                                    }
                                                </li>
                                                <li>
                                                    <form method="post" asp-page-handler="RemoveSponsor">
                                                        <input type="hidden" name="sponsorId" value="@sponsor.SponsorId" />
                                                        <button type="submit" class="dropdown-item text-danger">Remove account</button>
                                                    </form>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h5">Admin Accounts (@Model.Admins.Count)</h2>
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Created</th>
                                <th>Last Login</th>
                                <th>Last Login IP</th>
                                <th>Last Failed IP</th>
                                <th>Failed Attempts</th>
                                <th>Lockout Ends</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var admin in Model.Admins)
                            {
                                <tr>
                                    <td>@admin.DisplayName</td>
                                    <td>@admin.Email</td>
                                    <td>@admin.CreatedAt</td>
                                    <td>@admin.LastLoginAt</td>
                                    <td>@admin.LastLoginIp</td>
                                    <td>@admin.LastFailedLoginIp</td>
                                    <td>@admin.FailedLoginAttempts</td>
                                    <td>@admin.LockoutEndAt</td>
                                    <td>
                                        @if (admin.IsSuspended)
                                        {
                                            <span class="badge bg-danger">Suspended</span>
                                        }
                                        else if (admin.MustResetPassword)
                                        {
                                            <span class="badge bg-warning text-dark">Reset Required</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        @if (admin.IsCurrentAdmin)
                                        {
                                            <span class="text-muted small">Current account</span>
                                        }
                                        else
                                        {
                                            <div class="dropdown">
                                                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                                    &#x22EE;
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end">
                                                    <li>
                                                        <form method="post" asp-page-handler="ForceAdminReset">
                                                            <input type="hidden" name="adminId" value="@admin.AdminId" />
                                                            <button type="submit" class="dropdown-item">Require password reset</button>
                                                        </form>
                                                    </li>
                                                    <li>
                                                        <form method="post" asp-page-handler="RevokeSessions">
                                                            <input type="hidden" name="role" value="Admin" />
                                                            <input type="hidden" name="userId" value="@admin.AdminId" />
                                                            <button type="submit" class="dropdown-item">Revoke active sessions</button>
                                                        </form>
                                                    </li>
                                                    <li>
                                                        @if (admin.IsSuspended)
                                                        {
                                                            <form method="post" asp-page-handler="UnsuspendAdmin">
                                                                <input type="hidden" name="adminId" value="@admin.AdminId" />
                                                                <button type="submit" class="dropdown-item text-success">Unsuspend account</button>
                                                            </form>
                                                        }
                                                        else
                                                        {
                                                            <form method="post" asp-page-handler="SuspendAdmin">
                                                                <input type="hidden" name="adminId" value="@admin.AdminId" />
                                                                <button type="submit" class="dropdown-item text-warning">Suspend account</button>
                                                            </form>
                                                        }
                                                    </li>
                                                </ul>
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <h2 class="h5 mb-0">Active Sessions</h2>
                    <span class="text-muted small">Showing up to 100 currently active sessions</span>
                </div>
                @if (Model.ActiveSessions.Count == 0)
                {
                    <p class="text-muted mb-0 mt-3">No active sessions found.</p>
                }
                else
                {
                    <div class="table-responsive mt-3">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Role</th>
                                    <th>User Id</th>
                                    <th>IP</th>
                                    <th>User Agent</th>
                                    <th>Created</th>
                                    <th>Last Seen</th>
                                    <th>Expires</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var session in Model.ActiveSessions)
                                {
                                    <tr>
                                        <td>@session.Role</td>
                                        <td>@session.UserId</td>
                                        <td>@session.IpAddress</td>
                                        <td class="small">@session.UserAgent</td>
                                        <td>@session.CreatedAt</td>
                                        <td>@session.LastSeenAt</td>
                                        <td>@session.ExpiresAt</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
