@page
@model DriverRewards.Pages.Admin.ManageSponsorsModel
@{
    ViewData["Title"] = "Manage Sponsors";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Manage Sponsors</h2>
        <a asp-page="./CreateSponsor" class="btn btn-success">Add New Sponsor</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Points Ratio</th>
                <th>Joined</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Sponsors)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Email</td>
                    <td>@item.Phone</td>
                    <td>@item.DollarToPointRatio</td>
                    <td>@item.CreatedAt.ToShortDateString()</td>
                    <td>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@item.SponsorId" 
                              onsubmit="return confirm('Are you sure you want to delete this sponsor? This action cannot be undone.');">
                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>