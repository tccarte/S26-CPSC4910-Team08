<!DOCTYPE html>
@using System.Security.Claims
@using DriverRewards.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@{
    var requestPath = Context.Request.Path.Value ?? "";

    var isAuthPage =
        requestPath.Equals("/Login", StringComparison.OrdinalIgnoreCase) ||
        requestPath.Equals("/CreateAccount", StringComparison.OrdinalIgnoreCase) ||
        requestPath.EndsWith("/SignUp", StringComparison.OrdinalIgnoreCase);

    var currentPage = ViewContext.RouteData.Values["page"]?.ToString();
    var showDriverBalanceWidget = false;
    var driverBalancePoints = 0;
    var unreadNotificationCount = 0;
    var searchActionPage = User.IsInRole("Driver") ? "/Driver/Catalog" : "/Index";
    var searchQueryValue = Context.Request.Query["SearchQuery"].ToString();

    if (string.IsNullOrWhiteSpace(searchQueryValue))
    {
        searchQueryValue = Context.Request.Query["q"].ToString();
    }

    if (!isAuthPage
        && (User.Identity?.IsAuthenticated ?? false)
        && User.IsInRole("Driver")
        && !string.Equals(currentPage, "/Driver/Dashboard", StringComparison.OrdinalIgnoreCase))
    {
        var userIdClaim = User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (!string.IsNullOrWhiteSpace(userIdClaim))
        {
            var parts = userIdClaim.Split(':', 2, StringSplitOptions.TrimEntries);
            if (parts.Length == 2
                && string.Equals(parts[0], "Driver", StringComparison.OrdinalIgnoreCase)
                && int.TryParse(parts[1], out var driverId))
            {
                var driver = await DbContext.Drivers.AsNoTracking()
                    .FirstOrDefaultAsync(d => d.DriverId == driverId);

                if (driver != null)
                {
                    driverBalancePoints = driver.NumPoints ?? 0;
                    showDriverBalanceWidget = true;

                    unreadNotificationCount = await DbContext.DriverNotifications
                        .CountAsync(n => n.DriverId == driverId && !n.IsRead);
                }
            }
        }
    }
}
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DriverRewards</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DriverRewards.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="dr-nav">
            <div class="dr-nav-inner">
                <div class="dr-nav-links">
                    <a class="dr-link dr-link-plain dr-nav-item" asp-area="" asp-page="/About">About</a>

                    @if (!isAuthPage && User.IsInRole("Driver"))
                    {
                        <div class="dropdown dr-nav-item">
                            <button class="btn dr-link dr-link-plain dropdown-toggle" type="button" id="driverMenuDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                Driver Menu
                            </button>
                            <ul class="dropdown-menu" aria-labelledby="driverMenuDropdown">
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-page="/Driver/Dashboard">Dashboard</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-page="/Driver/Behaviors">Earning Behaviors</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-page="/Profile">Profile</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-page="/Driver/Catalog">Catalog</a>
                                </li>
                                <li>
                                    <a class="dropdown-item d-flex align-items-center gap-2" asp-area="" asp-page="/Driver/Notifications">
                                        Notifications
                                        @if (unreadNotificationCount > 0)
                                        {
                                            <span class="rounded-circle bg-danger" style="width:10px;height:10px;display:inline-block;flex-shrink:0;" title="@unreadNotificationCount unread"></span>
                                        }
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }

                    @if (!isAuthPage && User.IsInRole("Sponsor"))
                    {
                        <div class="dropdown dr-nav-item">
                            <button class="btn dr-link dr-link-plain dropdown-toggle" type="button" id="myOrganizationDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                My Organization
                            </button>
                            <ul class="dropdown-menu" aria-labelledby="myOrganizationDropdown">
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-page="/Sponsor/ManagePoints">Manage Points</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-page="/Sponsor/ManageBehaviors">Manage Behaviors</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-page="/Sponsor/ManageCatalog">Manage Catalog</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-page="/Sponsor/BulkMessage">Send Bulk Message</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-page="/Sponsor/Settings">Settings</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-page="/Sponsor/Help">Help</a>
                                </li>
                            </ul>
                        </div>
                    }

                    @if (!isAuthPage && User.IsInRole("Admin"))
                    {
                        <div class="dropdown dr-nav-item">
                            <button class="btn dr-link dr-link-plain dropdown-toggle" type="button" id="systemAdminDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                System Admin
                            </button>
                            <ul class="dropdown-menu" aria-labelledby="systemAdminDropdown">
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-page="/Admin/Dashboard">Dashboard</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-page="/Admin/CreateAdmin">Create Admin</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-page="/Admin/ManageBehaviors">Manage Behaviors</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-page="/Admin/Audit">Audit Center</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-page="/Admin/Schema">Database Schema</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="" asp-page="/Admin/Settings">Settings</a>
                                </li>
                            </ul>
                        </div>
                    }
                </div>

                <div class="dr-nav-tools">
                    @if (!isAuthPage)
                    {
                        <form class="dr-search dr-search-wide dr-nav-item" method="get" asp-page="@searchActionPage">
                            <input class="dr-search-input" type="search" name="SearchQuery" value="@searchQueryValue" placeholder="Search DriverRewards" aria-label="Search" />
                            <button class="dr-search-btn" type="submit">Search</button>
                        </form>

                        <div class="dr-actions">
                            @if (User.Identity?.IsAuthenticated ?? false)
                            {
                                <form class="d-inline" method="post" asp-page="/Logout">
                                    <button type="submit" class="dr-link dr-link-plain dr-nav-item">Logout</button>
                                </form>
                            }
                            else
                            {
                                <a class="dr-link dr-link-plain dr-nav-item" asp-area="" asp-page="/Login">Account &amp; Login</a>
                            }

                            <a class="dr-link dr-link-plain dr-nav-item dr-link-dark" asp-area="" asp-page="/Driver/Orders">Returns &amp; Orders</a>
                            <a class="dr-link dr-link-plain dr-nav-item dr-link-dark" asp-area="" asp-page="/Driver/Cart">Cart</a>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - DriverRewards - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (!isAuthPage && showDriverBalanceWidget)
    {
        <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1080; max-width: 320px;">
            <div class="card shadow-lg border-0">
                <div class="card-body">
                    <div class="text-muted small">Your Balance</div>
                    <div class="fs-5 fw-bold text-success">@driverBalancePoints points</div>
                </div>
            </div>
        </div>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
