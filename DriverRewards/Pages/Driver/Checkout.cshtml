@page
@model DriverRewards.Pages.Driver.CheckoutModel
@{
    ViewData["Title"] = "Checkout";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Checkout</h1>
    <a asp-page="/Driver/Cart" class="btn btn-outline-secondary">Back to Cart</a>
</div>

@if (!Model.Items.Any())
{
    <div class="alert alert-info">Your cart is empty.</div>
}
else
{
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h5 mb-3">Shipping Address</h2>

                    <form method="post" novalidate>
                        <div class="mb-3">
                            <label asp-for="Input.FullName" class="form-label"></label>
                            <input asp-for="Input.FullName" class="form-control" />
                            <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.AddressLine1" class="form-label"></label>
                            <input asp-for="Input.AddressLine1" class="form-control" />
                            <span asp-validation-for="Input.AddressLine1" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.AddressLine2" class="form-label"></label>
                            <input asp-for="Input.AddressLine2" class="form-control" />
                            <span asp-validation-for="Input.AddressLine2" class="text-danger small"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-5">
                                <label asp-for="Input.City" class="form-label"></label>
                                <input asp-for="Input.City" class="form-control" />
                                <span asp-validation-for="Input.City" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Input.State" class="form-label"></label>
                                <input asp-for="Input.State" class="form-control" />
                                <span asp-validation-for="Input.State" class="text-danger small"></span>
                            </div>
                            <div class="col-md-3">
                                <label asp-for="Input.PostalCode" class="form-label"></label>
                                <input asp-for="Input.PostalCode" class="form-control" />
                                <span asp-validation-for="Input.PostalCode" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mt-3 mb-4">
                            <label asp-for="Input.Country" class="form-label"></label>
                            <input asp-for="Input.Country" class="form-control" />
                            <span asp-validation-for="Input.Country" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary">Place Order with @Model.PointsToCharge Points</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-primary-subtle">
                <div class="card-body">
                    <h2 class="h5 mb-3">Order Summary</h2>
                    <ul class="list-group list-group-flush">
                        @foreach (var item in Model.Items)
                        {
                            <li class="list-group-item px-0 d-flex justify-content-between">
                                <span>@item.Name x @item.Quantity</span>
                                <span>@(item.PriceInPoints * item.Quantity)</span>
                            </li>
                        }
                    </ul>

                    <hr />

                    <div class="d-flex justify-content-between">
                        <span>Current Points</span>
                        <strong>@Model.CurrentPoints</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Cart Total</span>
                        <strong>@Model.TotalPoints</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Points Charged</span>
                        <strong>@Model.PointsToCharge</strong>
                    </div>
                    <div class="d-flex justify-content-between mt-2">
                        <span>Balance After Checkout</span>
                        <strong>@(Model.CurrentPoints - Model.PointsToCharge)</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
