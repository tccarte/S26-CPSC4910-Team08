@page
@model DriverRewards.Pages.Driver.CatalogModel
@{
    ViewData["Title"] = "Sponsor Catalog";
}

<h1>@ViewData["Title"]</h1>

<div class="container">
    <form method="get" class="mb-4">
        <div class="input-group">
            <input type="text" asp-for="SearchQuery" class="form-control" placeholder="Search products by name or description...">
            <button type="submit" class="btn btn-primary">Search</button>
        </div>
    </form>
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
        <div class="text-muted">
            @if (!string.IsNullOrWhiteSpace(Model.SponsorName))
            {
                <span>Showing catalog for <strong>@Model.SponsorName</strong>.</span>
            }
        </div>
        @if (Model.TotalProducts > 0)
        {
            <div class="text-muted small">@Model.TotalProducts item(s), page @Model.PageNumber of @Model.TotalPages</div>
        }
    </div>
    <div class="row">
        @if (Model.Products != null && Model.Products.Any())
        {
            foreach (var product in Model.Products)
            {
                <div class="col-sm-6 col-lg-3 mb-4">
                    <a asp-page="/Driver/ProductDetails" asp-route-id="@product.Id" class="text-decoration-none text-reset">
                    <div class="card h-100 shadow-sm">
                        
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <img src="@product.ImageUrl" class="card-img-top p-4" alt="@product.Name" style="height: 250px; object-fit: contain;">
                        }
                        
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@product.Name</h5>
                            
                            <p class="card-text text-muted small" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                @product.Description
                            </p>
                            
                            <div class="mt-auto">
                                <p class="card-text fs-5"><strong>@product.PriceInPoints</strong> points</p>
                                <span class="btn btn-outline-primary btn-sm">View details</span>
                            </div>
                        </div>
                    </div>
                    </a>
                </div>
            }
        }
        else
        {
            <p>No products are available in your sponsor catalog right now.</p>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Catalog pages">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.HasPreviousPage ? string.Empty : "disabled")">
                    <a class="page-link"
                       asp-page="/Driver/Catalog"
                       asp-route-CurrentPage="@(Model.PageNumber - 1)"
                       asp-route-SearchQuery="@Model.SearchQuery">Previous</a>
                </li>

                @for (var pageIndex = 1; pageIndex <= Model.TotalPages; pageIndex++)
                {
                    <li class="page-item @(pageIndex == Model.PageNumber ? "active" : string.Empty)">
                        <a class="page-link"
                           asp-page="/Driver/Catalog"
                           asp-route-CurrentPage="@pageIndex"
                           asp-route-SearchQuery="@Model.SearchQuery">@pageIndex</a>
                    </li>
                }

                <li class="page-item @(Model.HasNextPage ? string.Empty : "disabled")">
                    <a class="page-link"
                       asp-page="/Driver/Catalog"
                       asp-route-CurrentPage="@(Model.PageNumber + 1)"
                       asp-route-SearchQuery="@Model.SearchQuery">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>
